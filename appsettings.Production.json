{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "",
          "restrictedToMinimumLevel": "Information",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      },
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "QuakePulse.WebService",
      "Environment": "Production"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "",
    "EnableAdaptiveSampling": true,

    "SamplingSettings": {
      "IsEnabled": true,
      "MaxTelemetryItemsPerSecond": 1,
      "ExcludedTypes": "Request;Exception",
      "IncludedTypes": "Dependency;Trace"
    }

  },
  "AllowedHosts": "*",
  "ExternalApis": {
    "UsgsEarthquakeApi": {
      "BaseAddress": "https://earthquake.usgs.gov/fdsnws/event/1/"
    }
  },
  "Redis": {
    "ConnectionString": "",
    "DefaultTTLMinutes": 30,
    "AbortOnConnectFail": false,
    "ConnectRetry": 3,
    "ConnectTimeoutMs": 5000
  },
  "CacheSettings": {
    "Enabled": true,
    "LockDurationSeconds": 60,
    "LockWaitTimeMs": 200,
    "MaxLockWaitAttempts": 150
  },
  "ApiSettings": {
    "HttpClientTimeoutSeconds": 45,
    "RetryAttempts": 5
  }
}
