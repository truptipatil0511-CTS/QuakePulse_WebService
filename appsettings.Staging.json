{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/quakepulse-.txt",
          "rollingInterval": "Day",
          "rollingOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProperty"
    ],
    "Properties": {
      "Application": "QuakePulse.WebService",
      "Environment": "Staging"
    }
  },
  "AllowedHosts": "*.staging.yourdomain.com",
  "ExternalApis": {
    "UsgsEarthquakeApi": {
      "BaseAddress": "https://earthquake.usgs.gov/fdsnws/event/1/"
    }
  },
  "Redis": {
    "ConnectionString": "your-staging-redis-connection.redis.cache.windows.net:6380,password=your-password,ssl=true",
    "DefaultTTLMinutes": 20
  },
  "CacheSettings": {
    "Enabled": false,
    "LockDurationSeconds": 45,
    "LockWaitTimeMs": 150,
    "MaxLockWaitAttempts": 200
  },
  "ApiSettings": {
    "HttpClientTimeoutSeconds": 35,
    "RetryAttempts": 4
  }
}
