{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/quakepulse-.txt",
          "rollingInterval": "Day",
          "rollingOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProperty"
    ],
    "Properties": {
      "Application": "QuakePulse.WebService",
      "Environment": "Staging"
    }
  },
  "ApplicationInsights": {
    "EnableAdaptiveSampling": true,
    "SamplingSettings": {
      "IsEnabled": true,
      "MaxTelemetryItemsPerSecond": 5,
      "ExcludedTypes": "Exception",
      "IncludedTypes": "Request;Dependency;Trace"
    }
  },
  "AllowedHosts": "*.staging.yourdomain.com",
  "ExternalApis": {
    "UsgsEarthquakeApi": {
      "BaseAddress": "https://earthquake.usgs.gov/fdsnws/event/1/"
    }
  },
  "Redis": {
    "DefaultTTLMinutes": 20,
    "AbortOnConnectFail": false,
    "ConnectRetry": 3,
    "ConnectTimeoutMs": 5000
  },
  "CacheSettings": {
    "Enabled": true,
    "LockDurationSeconds": 45,
    "LockWaitTimeMs": 150,
    "MaxLockWaitAttempts": 200
  },
  "ApiSettings": {
    "HttpClientTimeoutSeconds": 35,
    "RetryAttempts": 4
  }
}
